NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Google Tag Manager container ID. Only fires when NEXT_PUBLIC_APP_ENV=production
# (see app/layout.tsx) so local/dev traffic never reaches GTM.
NEXT_PUBLIC_GTM_ID=
