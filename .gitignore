# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# demo seed (contiene credenciales demo, no versionar)
supabase/seed-demo-users.sh

# Supabase CLI local link state (which project you're linked to, per machine)
supabase/.temp/

# AI tooling local state (SDD skill registry, not for the repo)
.atl/

# Claude Code local settings (per-machine, not for the repo)
.claude/settings.local.json

# Claude Code personal skills fetched via skills-lock.json (per-developer
# tooling, not product code). Project-authored skills like run-kynea-life
# stay tracked via the negated exception below.
.agents/skills/
skills-lock.json
.claude/skills/*
!.claude/skills/run-kynea-life
